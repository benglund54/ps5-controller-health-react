# Frontend (safe defaults)
VITE_API_BASE_URL=http://localhost:3001

# Local server runtime
NODE_ENV=development
PORT=3001

# Salesforce CLI alias for local read services
SF_ORG_ALIAS=ps5-controller-demo

# Feature flags (server-controlled)
FEATURE_USE_CRM_READS=false
FEATURE_USE_DATA_CLOUD=false
FEATURE_USE_AGENTFORCE=false
FEATURE_FORCE_MOCK_FALLBACK=true

# Data source selectors
DATA_SOURCE_PRIORITY=mock,csv,crm,data_cloud,agentforce
CSV_DATA_PATH=./data/controller-health.csv
SNOWFLAKE_ENABLED=false
SNOWFLAKE_ACCOUNT=<your_snowflake_account>
SNOWFLAKE_WAREHOUSE=<your_snowflake_warehouse>
SNOWFLAKE_DATABASE=<your_snowflake_database>
SNOWFLAKE_SCHEMA=<your_snowflake_schema>

# Agentforce placeholders (server-side only)
AGENTFORCE_APP_NAME=<agentforce_app_name>
AGENTFORCE_TIMEOUT_MS=5000

# Logging / safety
LOG_LEVEL=info
REDACT_SENSITIVE_LOGS=true
